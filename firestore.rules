rules_version = '2';
// Finance App Firebase Security Rules
// Deploy: firebase deploy --only firestore (from project root)
// All rules: any authenticated user can read/write (app enforces sender/recipient in code)
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /accounts/{accountId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /cards/{cardId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /transactions/{transactionId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /notifications/{notificationId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /pending_transfer_requests/{requestId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
